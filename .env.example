# Copy to `.env` (same folder as docker-compose.yml) and adjust.

# --- Postgres ---
POSTGRES_DB=forge
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge

# --- Backend ---
# JWT signing secret for HS256 — must be at least 32 bytes.
# Generate one, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-bytes

# --- Web (reference; set by docker-compose for the LAN deploy) ---
# BACKEND_URL=http://backend:8080
# AUTH_COOKIE_SECURE=false   # false for LAN http; true (or unset in prod) for HTTPS
